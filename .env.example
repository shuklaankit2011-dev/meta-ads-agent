# ─────────────────────────────────────────
# META ADS AGENT — ENVIRONMENT VARIABLES
# ─────────────────────────────────────────
# 1. Copy this file and rename it to .env
# 2. Fill in your actual values below
# 3. NEVER commit .env to GitHub

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Meta Access Token
# Get from: https://developers.facebook.com → My Apps → Marketing API → Generate Token
# Required permission: ads_read, ads_management
META_ACCESS_TOKEN=your_meta_token_here

# Meta Ad Account ID (format: act_XXXXXXXXXX)
# Find in Meta Ads Manager → top left dropdown → copy account ID
META_AD_ACCOUNT_ID=act_your_account_id_here
